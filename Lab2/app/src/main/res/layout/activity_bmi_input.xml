<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/atmospheric_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="@dimen/bmi_screen_padding"
        android:paddingBottom="@dimen/bmi_screen_padding"
        android:paddingStart="@dimen/bmi_screen_padding"
        android:paddingEnd="@dimen/bmi_screen_padding">

        <!-- Responsive guidelines for tablet centering -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="@dimen/bmi_content_margin_horizontal"/>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="@dimen/bmi_content_margin_horizontal"/>

        <!-- Decorative header background with gradient -->
        <View
            android:id="@+id/headerBackground"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/header_gradient"
            app:layout_constraintBottom_toTopOf="@id/cardInput"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Accent glow line -->
        <View
            android:id="@+id/accentLine"
            android:layout_width="80dp"
            android:layout_height="4dp"
            android:background="@color/electric_cyan"
            android:alpha="0.8"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="@id/guideLeft"
            app:layout_constraintEnd_toEndOf="@id/guideRight"
            android:layout_marginTop="32dp"/>

        <!-- Header Title with distinctive typography -->
        <TextView
            android:id="@+id/tvBmiTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="BMI CALCULATOR"
            android:textAlignment="center"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/bmi_title_text_size"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/accentLine"
            app:layout_constraintEnd_toEndOf="@id/guideRight"
            app:layout_constraintStart_toStartOf="@id/guideLeft" />

        <!-- Subtitle with cyan accent -->
        <TextView
            android:id="@+id/tvBmiSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="// QUANTIFY YOUR WELLNESS"
            android:textSize="@dimen/bmi_subtitle_text_size"
            android:textColor="@color/soft_cyan"
            android:textAlignment="center"
            android:fontFamily="monospace"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvBmiTitle"
            app:layout_constraintStart_toStartOf="@id/guideLeft"
            app:layout_constraintEnd_toEndOf="@id/guideRight"/>

        <!-- Input Card with glow effect -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/midnight_blue"
            app:layout_constraintTop_toBottomOf="@id/tvBmiSubtitle"
            app:layout_constraintStart_toStartOf="@id/guideLeft"
            app:layout_constraintEnd_toEndOf="@id/guideRight">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/bmi_card_padding"
                android:background="@drawable/card_background_glow">

                <!-- Name Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilName"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="FULL NAME"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                    app:startIconTint="@color/electric_cyan"
                    app:hintTextColor="@color/text_secondary"
                    app:boxStrokeColor="@color/electric_cyan"
                    app:boxStrokeWidth="2dp"
                    app:boxBackgroundColor="@color/slate_gray"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:textSize="@dimen/bmi_input_text_size"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-light"
                        android:imeOptions="actionNext"
                        android:minHeight="48dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Age Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilAge"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/bmi_field_spacing"
                    android:hint="AGE"
                    app:startIconDrawable="@android:drawable/ic_menu_today"
                    app:startIconTint="@color/electric_cyan"
                    app:hintTextColor="@color/text_secondary"
                    app:boxStrokeColor="@color/electric_cyan"
                    app:boxStrokeWidth="2dp"
                    app:boxBackgroundColor="@color/slate_gray"
                    app:suffixText="years"
                    app:suffixTextColor="@color/text_tertiary"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textSize="@dimen/bmi_input_text_size"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-light"
                        android:imeOptions="actionNext"
                        android:minHeight="48dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Height & Weight Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:layout_marginTop="@dimen/bmi_field_spacing">

                    <!-- Height Field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilHeight"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="HEIGHT"
                        app:startIconDrawable="@android:drawable/arrow_up_float"
                        app:startIconTint="@color/electric_cyan"
                        app:hintTextColor="@color/text_secondary"
                        app:boxStrokeColor="@color/electric_cyan"
                        app:boxStrokeWidth="2dp"
                        app:boxBackgroundColor="@color/slate_gray"
                        app:suffixText="cm"
                        app:suffixTextColor="@color/text_tertiary"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etHeight"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textSize="@dimen/bmi_input_text_size"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-light"
                            android:imeOptions="actionNext"
                            android:minHeight="48dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Weight Field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilWeight"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:hint="WEIGHT"
                        app:startIconDrawable="@android:drawable/ic_menu_compass"
                        app:startIconTint="@color/electric_cyan"
                        app:hintTextColor="@color/text_secondary"
                        app:boxStrokeColor="@color/electric_cyan"
                        app:boxStrokeWidth="2dp"
                        app:boxBackgroundColor="@color/slate_gray"
                        app:suffixText="kg"
                        app:suffixTextColor="@color/text_tertiary"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etWeight"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textSize="@dimen/bmi_input_text_size"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-light"
                            android:imeOptions="actionDone"
                            android:minHeight="48dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Calculate Button with neon gradient -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCalculate"
            android:layout_width="0dp"
            android:layout_height="@dimen/bmi_button_height"
            android:layout_marginTop="28dp"
            android:text="▸ CALCULATE"
            android:textSize="@dimen/bmi_button_text_size"
            android:textStyle="bold"
            android:textColor="@color/deep_navy"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            app:backgroundTint="@color/electric_cyan"
            app:cornerRadius="28dp"
            app:elevation="6dp"
            app:strokeColor="@color/neon_cyan"
            app:strokeWidth="2dp"
            android:minHeight="48dp"
            app:layout_constraintTop_toBottomOf="@id/cardInput"
            app:layout_constraintStart_toStartOf="@id/guideLeft"
            app:layout_constraintEnd_toEndOf="@id/guideRight"/>

        <!-- Footer Message with tech aesthetic -->
        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:paddingBottom="24dp"
            android:text="[ OPTIMIZE YOUR HEALTH METRICS ]"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textAlignment="center"
            app:layout_constraintTop_toBottomOf="@id/btnCalculate"
            app:layout_constraintStart_toStartOf="@id/guideLeft"
            app:layout_constraintEnd_toEndOf="@id/guideRight"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
