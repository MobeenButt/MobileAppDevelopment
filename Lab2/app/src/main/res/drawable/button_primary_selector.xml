<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="90"
                        android:startColor="#00C7E6"
                        android:endColor="#00B8D4"
                        android:type="linear"/>
                    <corners android:radius="28dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#00F5FF"
                android:endColor="#00D9FF"
                android:type="linear"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
</selector>

