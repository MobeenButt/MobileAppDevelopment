<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Neon glow effect -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#3300F5FF"
                android:centerColor="#1A00F5FF"
                android:endColor="#0000F5FF"
                android:type="linear"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <!-- Main card -->
    <item android:top="3dp" android:left="3dp" android:right="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#1E2749"
                android:endColor="#141B3D"
                android:type="linear"/>
            <corners android:radius="13dp"/>
            <stroke android:width="1.5dp" android:color="#00F5FF" android:alpha="0.6"/>
        </shape>
    </item>
</layer-list>

