<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="@dimen/bmi_screen_padding"
        android:paddingBottom="@dimen/bmi_screen_padding"
        android:paddingStart="@dimen/bmi_screen_padding"
        android:paddingEnd="@dimen/bmi_screen_padding">

        <!-- Responsive guidelines for tablet centering -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="@dimen/bmi_content_margin_horizontal"/>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="@dimen/bmi_content_margin_horizontal"/>

        <!-- Decorative header background -->
        <View
            android:id="@+id/headerBackground"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/header_gradient"
            app:layout_constraintBottom_toTopOf="@id/cardInput"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvBmiTitle" />

        <!-- Icon -->

        <!-- Header Title -->
        <TextView
            android:id="@+id/tvBmiTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="BMI Calculator"
            android:textAlignment="center"
            android:textColor="#1A237E"
            android:textSize="@dimen/bmi_title_text_size"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@id/guideRight"
            app:layout_constraintStart_toStartOf="@id/guideLeft"
            tools:layout_editor_absoluteY="121dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvBmiSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Track your health with ease"
            android:textSize="@dimen/bmi_subtitle_text_size"
            android:textColor="#616161"
            android:textAlignment="center"
            android:fontFamily="sans-serif"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvBmiTitle"
            app:layout_constraintStart_toStartOf="@id/guideLeft"
            app:layout_constraintEnd_toEndOf="@id/guideRight"/>

        <!-- Input Card with elevation and rounded corners -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/bmi_card_margin_top"
            app:cardCornerRadius="@dimen/bmi_card_corner_radius"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/tvBmiSubtitle"
            app:layout_constraintStart_toStartOf="@id/guideLeft"
            app:layout_constraintEnd_toEndOf="@id/guideRight">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/bmi_card_padding">

                <!-- Name Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilName"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Full Name"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                    app:startIconTint="#5E35B1"
                    app:hintTextColor="#5E35B1"
                    app:boxStrokeColor="#5E35B1"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:textSize="@dimen/bmi_input_text_size"
                        android:textColor="#212121"
                        android:imeOptions="actionNext"
                        android:minHeight="48dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Age Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilAge"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/bmi_field_spacing"
                    android:hint="Age"
                    app:startIconDrawable="@android:drawable/ic_menu_today"
                    app:startIconTint="#5E35B1"
                    app:hintTextColor="#5E35B1"
                    app:boxStrokeColor="#5E35B1"
                    app:suffixText="years"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textSize="@dimen/bmi_input_text_size"
                        android:textColor="#212121"
                        android:imeOptions="actionNext"
                        android:minHeight="48dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Height & Weight Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:layout_marginTop="@dimen/bmi_field_spacing">

                    <!-- Height Field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilHeight"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="Height"
                        app:startIconDrawable="@android:drawable/arrow_up_float"
                        app:startIconTint="#5E35B1"
                        app:hintTextColor="#5E35B1"
                        app:boxStrokeColor="#5E35B1"
                        app:suffixText="cm"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etHeight"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textSize="@dimen/bmi_input_text_size"
                            android:textColor="#212121"
                            android:imeOptions="actionNext"
                            android:minHeight="48dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Weight Field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilWeight"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:hint="Weight"
                        app:startIconDrawable="@android:drawable/ic_menu_compass"
                        app:startIconTint="#5E35B1"
                        app:hintTextColor="#5E35B1"
                        app:boxStrokeColor="#5E35B1"
                        app:suffixText="kg"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etWeight"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textSize="@dimen/bmi_input_text_size"
                            android:textColor="#212121"
                            android:imeOptions="actionDone"
                            android:minHeight="48dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Calculate Button with Material Design elevation -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCalculate"
            android:layout_width="0dp"
            android:layout_height="@dimen/bmi_button_height"
            android:layout_marginTop="@dimen/bmi_button_margin_top"
            android:text="Calculate BMI"
            android:textSize="@dimen/bmi_button_text_size"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"
            app:backgroundTint="#5E35B1"
            app:cornerRadius="28dp"
            app:elevation="4dp"
            app:icon="@android:drawable/ic_menu_upload"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF"
            android:minHeight="48dp"
            app:layout_constraintTop_toBottomOf="@id/cardInput"
            app:layout_constraintStart_toStartOf="@id/guideLeft"
            app:layout_constraintEnd_toEndOf="@id/guideRight"/>

        <!-- Footer Message -->
        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:paddingBottom="24dp"
            android:text="Stay healthy, stay fit! 💪"
            android:textColor="#9E9E9E"
            android:textSize="@dimen/bmi_subtitle_text_size"
            android:fontFamily="sans-serif-light"
            android:textAlignment="center"
            app:layout_constraintTop_toBottomOf="@id/btnCalculate"
            app:layout_constraintStart_toStartOf="@id/guideLeft"
            app:layout_constraintEnd_toEndOf="@id/guideRight"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
